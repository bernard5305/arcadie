<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Planning Multi-Chantiers — ARCADIE</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0f0f13;
    --surface: #1a1a22;
    --surface2: #22222e;
    --border: #2e2e3e;
    --text: #f0ede8;
    --muted: #6b6880;
    --accent: #c8a96e;
    --green: #4ade80;
    --blue: #60a5fa;
    --purple: #a78bfa;
    --orange: #fb923c;
    --red: #f87171;
    --teal: #2dd4bf;
    --pink: #f472b6;
  }
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: var(--bg); color: var(--text); font-family: 'DM Sans', sans-serif; min-height: 100vh; }

  header {
    padding: 24px 32px 20px;
    border-bottom: 1px solid var(--border);
    display: flex; align-items: center; justify-content: space-between;
    background: var(--surface);
    position: sticky; top: 0; z-index: 100;
  }
  .logo-area { display: flex; align-items: center; gap: 16px; }
  .logo-text { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 18px; color: var(--accent); letter-spacing: 2px; }
  .logo-sub { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; }
  h1 { font-family: 'Syne', sans-serif; font-weight: 800; font-size: 22px; color: var(--text); }

  .controls {
    padding: 16px 32px;
    display: flex; align-items: center; gap: 16px; flex-wrap: wrap;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }
  .view-toggle { display: flex; gap: 4px; background: var(--bg); border-radius: 8px; padding: 4px; }
  .view-btn {
    padding: 6px 14px; border: none; border-radius: 6px; cursor: pointer;
    font-family: 'DM Sans', sans-serif; font-size: 12px; font-weight: 500;
    background: transparent; color: var(--muted); transition: all .2s;
  }
  .view-btn.active { background: var(--accent); color: #1a1200; }

  .legend { display: flex; gap: 16px; flex-wrap: wrap; margin-left: auto; }
  .legend-item { display: flex; align-items: center; gap: 6px; font-size: 12px; color: var(--muted); }
  .legend-dot { width: 10px; height: 10px; border-radius: 2px; }

  /* GANTT */
  .gantt-wrap { overflow-x: auto; padding: 24px 32px; }
  .gantt { min-width: 900px; }

  .gantt-header {
    display: grid; align-items: center;
    border-bottom: 1px solid var(--border);
    margin-bottom: 0;
    position: sticky; top: 73px; z-index: 50;
    background: var(--bg);
  }
  .gantt-header-label {
    font-size: 11px; text-transform: uppercase; letter-spacing: 1px;
    color: var(--muted); padding: 8px 0 8px 8px;
  }
  .months-row { display: flex; border-bottom: 1px solid var(--border); background: var(--bg); }
  .month-cell {
    text-align: center; font-size: 11px; font-weight: 600; color: var(--accent);
    text-transform: uppercase; letter-spacing: 1px; padding: 6px 0;
    border-right: 1px solid var(--border);
  }
  .today-line {
    position: absolute; top: 0; bottom: 0; width: 2px;
    background: var(--red); opacity: 0.8; z-index: 10;
    pointer-events: none;
  }
  .today-line::before {
    content: 'Aujourd\'hui';
    position: absolute; top: -20px; left: 50%; transform: translateX(-50%);
    font-size: 9px; color: var(--red); white-space: nowrap; font-family: 'DM Sans', sans-serif;
  }

  /* Chantier section */
  .chantier-section { margin-bottom: 8px; }
  .chantier-header {
    display: grid; align-items: center;
    background: var(--surface2);
    border-radius: 8px 8px 0 0;
    border: 1px solid var(--border);
    border-bottom: none;
    padding: 10px 0;
    cursor: pointer;
  }
  .chantier-name {
    font-family: 'Syne', sans-serif; font-weight: 700; font-size: 13px;
    color: var(--text); padding-left: 12px;
    display: flex; align-items: center; gap: 8px;
  }
  .chantier-period { font-size: 10px; color: var(--muted); font-weight: 400; }
  .chevron { transition: transform .2s; font-size: 10px; color: var(--muted); }
  .chantier-section.collapsed .chevron { transform: rotate(-90deg); }
  .chantier-section.collapsed .lots-container { display: none; }

  .lots-container {
    border: 1px solid var(--border);
    border-top: none;
    border-radius: 0 0 8px 8px;
    overflow: hidden;
  }

  .lot-row {
    display: grid; align-items: center;
    border-bottom: 1px solid var(--border);
    transition: background .15s;
  }
  .lot-row:last-child { border-bottom: none; }
  .lot-row:hover { background: rgba(200,169,110,0.04); }
  .lot-row.is-parent { background: rgba(255,255,255,0.02); }

  .lot-name {
    font-size: 12px; color: var(--text); padding: 8px 8px 8px 12px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }
  .lot-row.is-parent .lot-name { font-weight: 600; color: var(--accent); font-size: 12px; }
  .lot-row.is-child .lot-name { padding-left: 24px; color: var(--muted); font-size: 11px; }

  .bar-cell { position: relative; height: 32px; }
  .bar {
    position: absolute; height: 18px; top: 7px;
    border-radius: 4px; display: flex; align-items: center; padding: 0 6px;
    font-size: 10px; color: rgba(0,0,0,0.7); font-weight: 600;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    transition: opacity .2s; cursor: default;
  }
  .bar:hover { opacity: 0.85; filter: brightness(1.1); }
  .lot-row.is-parent .bar { height: 22px; top: 5px; border-radius: 5px; }
  .lot-row.is-child .bar { height: 14px; top: 9px; opacity: 0.8; }

  /* Vue par corps de métier */
  .corps-section { margin-bottom: 20px; }
  .corps-title {
    font-family: 'Syne', sans-serif; font-weight: 700; font-size: 14px;
    color: var(--text); padding: 12px 0 8px;
    display: flex; align-items: center; gap: 10px;
  }
  .corps-title::after { content: ''; flex: 1; height: 1px; background: var(--border); }
  .corps-bar-row {
    display: grid; align-items: center;
    border-bottom: 1px solid var(--border);
    padding: 4px 0;
  }
  .corps-bar-row:last-child { border: none; }
  .corps-chantier-name { font-size: 12px; color: var(--muted); padding-left: 12px; }

  .tooltip {
    position: fixed; z-index: 200; pointer-events: none;
    background: var(--surface2); border: 1px solid var(--border);
    border-radius: 8px; padding: 10px 14px; font-size: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    max-width: 220px;
    opacity: 0; transition: opacity .15s;
  }
  .tooltip.visible { opacity: 1; }
  .tooltip-title { font-weight: 600; color: var(--text); margin-bottom: 4px; }
  .tooltip-dates { color: var(--muted); font-size: 11px; }
  .tooltip-pct { color: var(--accent); font-size: 11px; margin-top: 3px; }

  .upload-zone {
    margin: 0 32px 24px;
    border: 2px dashed var(--border); border-radius: 12px;
    padding: 24px; text-align: center;
    color: var(--muted); font-size: 13px; cursor: pointer;
    transition: border-color .2s, background .2s;
  }
  .upload-zone:hover { border-color: var(--accent); background: rgba(200,169,110,0.04); }
  .upload-zone input { display: none; }

  .stats-bar {
    display: flex; gap: 24px; padding: 12px 32px;
    border-bottom: 1px solid var(--border);
    background: var(--surface); flex-wrap: wrap;
  }
  .stat { font-size: 12px; color: var(--muted); }
  .stat strong { color: var(--text); font-weight: 600; }
</style>
</head>
<body>

<header>
  <div class="logo-area">
    <div>
      <div class="logo-text">ARCADIE</div>
      <div class="logo-sub">Maîtrise d'œuvre</div>
    </div>
  </div>
  <h1>Planning multi-chantiers</h1>
  <div class="view-toggle">
    <button class="view-btn active" onclick="setView('chantier')">Par chantier</button>
