      { nom: '06 - Plomberie / Clim', debut: '2026-04-13', fin: '2026-06-21', pct: 0, parent: true },
      { nom: '07 - Peinture', debut: '2026-06-22', fin: '2026-07-26', pct: 0, parent: true },
      { nom: '08 - Sol PVC', debut: '2026-07-06', fin: '2026-07-26', pct: 0, parent: true },
      { nom: '09 - Carrelage', debut: '2026-06-22', fin: '2026-07-12', pct: 0, parent: true },
      { nom: '10 - Cuisine', debut: '2026-07-27', fin: '2026-08-09', pct: 0, parent: true },
    ]
  }
];

// ===================== CALCULS DATES =====================
const allDates = CHANTIERS.flatMap(c => c.lots.flatMap(l => [new Date(l.debut), new Date(l.fin)]));
const minDate = new Date(Math.min(...allDates));
const maxDate = new Date(Math.max(...allDates));
minDate.setDate(1);
maxDate.setMonth(maxDate.getMonth() + 1, 1);

const totalDays = (maxDate - minDate) / 86400000;
const today = new Date();

function dateToX(dateStr) {
  const d = new Date(dateStr);
  return ((d - minDate) / 86400000) / totalDays * 100;
}
function daysToW(d1, d2) {
  return ((new Date(d2) - new Date(d1)) / 86400000) / totalDays * 100;
}

// ===================== MOIS HEADER =====================
function buildMonthsHeader(labelW) {
  const months = [];
  let cur = new Date(minDate);
  while (cur < maxDate) {
    const start = new Date(cur);
    const end = new Date(cur.getFullYear(), cur.getMonth() + 1, 1);
    const endCapped = end < maxDate ? end : maxDate;
    const w = ((endCapped - start) / 86400000) / totalDays * 100;
    months.push({ label: start.toLocaleDateString('fr-FR', { month: 'short', year: '2-digit' }), w });
    cur = end;
  }
  return `<div style="display:flex;margin-left:${labelW}px">` +
    months.map(m => `<div class="month-cell" style="width:${m.w}%">${m.label}</div>`).join('') +
    '</div>';
}

// ===================== VUE PAR CHANTIER =====================
function buildChantierView(labelW) {
  const todayX = dateToX(today.toISOString().slice(0,10));

  return CHANTIERS.map(c => {
    const rows = c.lots.map(lot => {
      const x = dateToX(lot.debut);
      const w = daysToW(lot.debut, lot.fin);
      const pctLabel = lot.pct !== null ? ` ${lot.pct}%` : '';
      return `
        <div class="lot-row ${lot.parent ? 'is-parent' : 'is-child'}"
             style="grid-template-columns:${labelW}px 1fr"
             onmouseenter="showTip(event,'${lot.nom.replace(/'/g,"\\'")}','${lot.debut}','${lot.fin}',${lot.pct})"
             onmouseleave="hideTip()">
          <div class="lot-name">${lot.nom}</div>
          <div class="bar-cell" style="position:relative">
            <div class="bar" style="left:${x}%;width:${w}%;background:${c.couleur};opacity:${lot.parent?1:0.65}">
              ${w > 5 ? lot.nom.split(' - ').pop().split(' ').slice(0,2).join(' ') + pctLabel : ''}
            </div>
          </div>
        </div>`;
    }).join('');

    return `
      <div class="chantier-section" id="sec_${c.id}">
        <div class="chantier-header" style="grid-template-columns:${labelW}px 1fr" onclick="toggleSection('sec_${c.id}')">
          <div class="chantier-name">
            <span class="chevron">▼</span>
            <span style="width:10px;height:10px;border-radius:2px;background:${c.couleur};display:inline-block"></span>
            ${c.nom}
            <span class="chantier-period">${fmtDate(c.debut)} → ${fmtDate(c.fin)}</span>
          </div>
          <div class="bar-cell" style="position:relative">
            <div class="bar" style="left:${dateToX(c.debut)}%;width:${daysToW(c.debut,c.fin)}%;background:${c.couleur};opacity:0.2;height:22px;top:5px"></div>
            <div class="today-line" style="left:${todayX}%"></div>
          </div>
        </div>
        <div class="lots-container">${rows}</div>
      </div>`;
  }).join('');
}

// ===================== VUE PAR CORPS =====================
const CORPS_KEYS = [
  { key: 'gros', label: 'Gros Œuvre / Démolition', color: '#fb923c', match: ['gros', 'demol', 'maçon', 'béton', 'ouverture', 'plancher'] },
  { key: 'charpente', label: 'Charpente / Couverture', color: '#f59e0b', match: ['charpente', 'couverture', 'toit', 'trémie', 'etanch'] },
  { key: 'menuiserie', label: 'Menuiserie', color: '#a78bfa', match: ['menuiserie', 'menuiseries'] },
  { key: 'platrerie', label: 'Plâtrerie', color: '#60a5fa', match: ['platrer', 'platrerie', 'sad', 'plafond', 'doublage', 'cloison', 'jointage', 'ossature'] },
  { key: 'electricite', label: 'Électricité', color: '#fbbf24', match: ['electr', 'électr', 'appareillage'] },
  { key: 'plomberie', label: 'Plomberie / Climatisation', color: '#2dd4bf', match: ['plomberie', 'plomb', 'clim', 'eu', 'alimentation', 'appareillage plomb'] },
  { key: 'peinture', label: 'Peinture', color: '#f472b6', match: ['peinture'] },
  { key: 'sols', label: 'Sols / Carrelage / Cuisine', color: '#4ade80', match: ['sol', 'sols', 'carrelage', 'cuisine', 'ragréage', 'pose des'] },
];

function getCorps(lotNom) {
  const n = lotNom.toLowerCase();
  for (const c of CORPS_KEYS) {
    if (c.match.some(m => n.includes(m))) return c;
  }
  return { key: 'other', label: 'Autres', color: '#6b7280' };
}

function buildCorpsView(labelW) {
  const todayX = dateToX(today.toISOString().slice(0,10));
  const byCorps = {};

  CHANTIERS.forEach(c => {
    c.lots.filter(l => l.parent).forEach(lot => {
      const corps = getCorps(lot.nom);
      if (!byCorps[corps.key]) byCorps[corps.key] = { ...corps, items: [] };
      byCorps[corps.key].items.push({ chantier: c.nom, couleur: c.couleur, lot });
    });
  });

  return Object.values(byCorps).map(corps => {
    const rows = corps.items.map(item => {
      const x = dateToX(item.lot.debut);
      const w = daysToW(item.lot.debut, item.lot.fin);
      return `
        <div class="corps-bar-row" style="grid-template-columns:${labelW}px 1fr"
             onmouseenter="showTip(event,'${item.lot.nom.replace(/'/g,"\\'")} — ${item.chantier.replace(/'/g,"\\'")}','${item.lot.debut}','${item.lot.fin}',${item.lot.pct})"
             onmouseleave="hideTip()">
          <div class="lot-name" style="font-size:12px;color:var(--muted);padding-left:12px">
            <span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:${item.couleur};margin-right:6px"></span>
            ${item.chantier}
          </div>
          <div class="bar-cell" style="position:relative">
            <div class="bar" style="left:${x}%;width:${w}%;background:${corps.color}">
              ${w > 4 ? item.lot.nom.split(' - ').pop().split(' ').slice(0,3).join(' ') : ''}
            </div>
            <div class="today-line" style="left:${todayX}%"></div>
          </div>
        </div>`;
    }).join('');

    return `
      <div class="corps-section">
        <div class="corps-title" style="color:${corps.color}">${corps.label}</div>
        <div style="border:1px solid var(--border);border-radius:8px;overflow:hidden">${rows}</div>
      </div>`;
  }).join('');
}

// ===================== RENDER =====================
let currentView = 'chantier';
const LABEL_W = 200;

function render() {
  const gantt = document.getElementById('gantt');
  const body = currentView === 'chantier'
    ? buildChantierView(LABEL_W)
    : buildCorpsView(LABEL_W);
  gantt.innerHTML = buildMonthsHeader(LABEL_W) + body;
  updateStats();
  updateLegend();
}

function setView(v) {
  currentView = v;
  document.querySelectorAll('.view-btn').forEach(b => b.classList.toggle('active', b.textContent.includes(v === 'chantier' ? 'chantier' : 'corps')));
  render();
}

function toggleSection(id) {
  document.getElementById(id).classList.toggle('collapsed');
}

function updateStats() {
  const today = new Date();
  const actifs = CHANTIERS.filter(c => new Date(c.debut) <= today && new Date(c.fin) >= today).length;
  const totalLots = CHANTIERS.reduce((s, c) => s + c.lots.filter(l => l.parent).length, 0);
  document.getElementById('stats-bar').innerHTML = `
    <div class="stat"><strong>${CHANTIERS.length}</strong> chantiers</div>
    <div class="stat"><strong>${actifs}</strong> en cours</div>
    <div class="stat"><strong>${totalLots}</strong> lots au total</div>
    <div class="stat">Du <strong>${fmtDate(minDate.toISOString().slice(0,10))}</strong> au <strong>${fmtDate(maxDate.toISOString().slice(0,10))}</strong></div>
  `;
}

function updateLegend() {
  document.getElementById('legend').innerHTML = CHANTIERS.map(c =>
    `<div class="legend-item"><div class="legend-dot" style="background:${c.couleur}"></div>${c.nom}</div>`
  ).join('');
}

// ===================== TOOLTIP =====================
function showTip(e, nom, debut, fin, pct) {
  const t = document.getElementById('tooltip');
  t.innerHTML = `<div class="tooltip-title">${nom}</div>
    <div class="tooltip-dates">📅 ${fmtDate(debut)} → ${fmtDate(fin)}</div>
    ${pct !== null ? `<div class="tooltip-pct">⏱ Avancement : ${pct}%</div>` : ''}`;
  t.classList.add('visible');
  moveTip(e);
}
function moveTip(e) {
  const t = document.getElementById('tooltip');
  t.style.left = (e.clientX + 12) + 'px';
  t.style.top = (e.clientY - 10) + 'px';
}
function hideTip() {
  document.getElementById('tooltip').classList.remove('visible');
}
document.addEventListener('mousemove', moveTip);

function fmtDate(d) {
  return new Date(d).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: '2-digit' });
}

render();
</script>
</body>
</html>
