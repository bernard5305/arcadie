      { nom: '01 - Gros Œuvre', debut: '2026-02-23', fin: '2026-04-17', pct: 0, parent: true },
      { nom: 'Démol Phase 1', debut: '2026-02-23', fin: '2026-03-01', pct: 0, parent: false },
