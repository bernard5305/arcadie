      { nom: 'Pose groupe', debut: '2026-04-26', fin: '2026-05-09', pct: 0, parent: false },
      { nom: '8 - Peinture', debut: '2026-05-11', fin: '2026-06-07', pct: 0, parent: true },
      { nom: '9 - Revêtement sol PVC', debut: '2026-06-08', fin: '2026-06-28', pct: 0, parent: true },
